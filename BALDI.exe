if game.Players.LocalPlayer.Name ~= "chaoban123674" then    returnendlocal Players = game:GetService("Players")local LocalPlayer = Players.LocalPlayerlocal Entities = {    eater = "https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Eater",    flee = "https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Flee",    rebound = "https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Rebound",    blackeyes = "https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Black%20Eyes",    depth4 = "https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Depth4",    hunter = "https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Hunter",    glitcher2 = "https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Glitcher2",    waiter = "https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Waiter",    looker = "https://raw.githubusercontent.com/eoyoustme/Extremely/refs/heads/main/Looker"}local function spawnEntity(name)    if Entities[name] then        pcall(function()            loadstring(game:HttpGet(Entities[name]))()        end)    endendlocal gui = Instance.new("ScreenGui")gui.Name = "AdminMenu"gui.Parent = game.CoreGuilocal frame = Instance.new("ScrollingFrame")frame.Parent = guiframe.Size = UDim2.new(0,220,0,430)frame.Position = UDim2.new(0,20,0.3,0)frame.BackgroundColor3 = Color3.fromRGB(20,20,20)frame.CanvasSize = UDim2.new(0,0,0,500)frame.ScrollBarThickness = 6local title = Instance.new("TextLabel")title.Parent = frametitle.Size = UDim2.new(1,0,0,40)title.Text = "ADMIN MENU"title.TextScaled = truetitle.BackgroundColor3 = Color3.fromRGB(40,40,40)title.TextColor3 = Color3.new(1,1,1)local function createButton(text, posY, entityName)    local button = Instance.new("TextButton")    button.Parent = frame    button.Size = UDim2.new(0.8,0,0,30)    button.Position = UDim2.new(0.1,0,0,posY)    button.Text = text    button.BackgroundColor3 = Color3.fromRGB(60,60,60)    button.TextColor3 = Color3.new(1,1,1)    button.MouseButton1Click:Connect(function()        spawnEntity(entityName)    end)endcreateButton("Eater", 50, "eater")createButton("Flee", 90, "flee")createButton("Rebound", 130, "rebound")createButton("Black Eyes", 170, "blackeyes")createButton("Depth4", 210, "depth4")createButton("Hunter", 250, "hunter")createButton("Glitcher2", 290, "glitcher2")createButton("Waiter", 330, "waiter")createButton("Looker", 370, "looker")local hide = Instance.new("TextButton")hide.Parent = framehide.Size = UDim2.new(0.2,0,0,25)hide.Position = UDim2.new(0.75,0,0,5)hide.Text = "-"hide.BackgroundColor3 = Color3.fromRGB(255,200,50)local openBtn = Instance.new("TextButton")openBtn.Parent = guiopenBtn.Size = UDim2.new(0,80,0,40)openBtn.Position = UDim2.new(0,20,0.3,0)openBtn.Text = "Open"openBtn.Visible = falseopenBtn.BackgroundColor3 = Color3.fromRGB(50,200,50)openBtn.TextColor3 = Color3.new(1,1,1)hide.MouseButton1Click:Connect(function()    frame.Visible = false    openBtn.Visible = trueend)openBtn.MouseButton1Click:Connect(function()    frame.Visible = true    openBtn.Visible = falseend)